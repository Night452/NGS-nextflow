process {
    withName: FASTQC {
        cpus = 2
        memory = '4 GB'
    }
    withName: FASTP {
        cpus = 4
        memory = '8 GB'
    }
    withName: STAR_INDEX {
        cpus = 4
        memory = '16 GB'
    }
    withName: STAR_ALIGN {
        cpus = 6
        memory = '16 GB'
    }
    withName: FEATURE_COUNTS {
        cpus = 2
        memory = '4 GB'
    }
}

profiles {
    docker {
        docker.enabled = true
        docker.runOptions = '-u $(id -u):$(id -g)'
    }
    singularity {
        singularity.enabled = true
        singularity.autoMounts = true
    }
}
